# SQLite is used by default and needs no external database server.
SQL_URL=sqlite:///./repo.db

# PostgreSQL can still be used by replacing SQL_URL, for example:
# SQL_URL=postgresql://postgres:password@localhost:5432/postgres

SECRET_KEY_JWT=VIBIRASHKA_CHANGE_ME
DEFAULT_ADMIN_EMAIL=admin@vibirashka.ru
DEFAULT_ADMIN_PASSWORD=Admin12345
